{
  "name": "canamed",
  "version": "0.0.0",
  "private": true,
  "description": "CaNaMED Franco-Japanese medical-education platform — research analysis + the live web app.",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:coverage": "c8 --reporter=text --reporter=lcov --reporter=html --include='docs/Third_session/PBL_platform/lib.js' --include='docs/Third_session/PBL_platform/i18n.js' --include='docs/Third_session/PBL_platform/localdb.js' --include='docs/Third_session/PBL_platform/telemetry.js' --include='docs/Third_session/PBL_platform/pure-utils.js' node --test tests/*.test.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "serve:platform": "node scripts/serve-platform.js",
    "i18n:coverage": "node scripts/i18n-coverage-report.js",
    "emulator": "npx firebase emulators:start --only=database,auth --config docs/Third_session/PBL_platform/firebase.json --project canamed-sim",
    "sim:emulator": "node scripts/sim/sim-with-emulator.js",
    "test:e2e:rules": "node scripts/sim/build-emulator-rules.js && npx firebase emulators:exec --only database,auth --config docs/Third_session/PBL_platform/firebase.emulator.json --project canamed-sim \"npx playwright test --config=playwright.emulator.config.js\""
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.49.0",
    "c8": "^11.0.0"
  }
}
