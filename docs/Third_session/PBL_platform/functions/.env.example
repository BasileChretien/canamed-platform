# Firebase Cloud Functions — params API config
# ─────────────────────────────────────────────────────────────────────
# Copy this file to `.env` (or `.env.<projectId>` for per-project overrides)
# and edit the values. The real file is .gitignored — never commit it.
#
# Secrets like HF_TOKEN do NOT belong here. Set them via:
#   firebase functions:secrets:set HF_TOKEN
# which stores them in Google Secret Manager (encrypted at rest, mounted
# only when the function runs).
# ─────────────────────────────────────────────────────────────────────

# Module A LLM-patient pilot. DORMANT until set to true.
# When false, hfPatient returns { state: "disabled" } and the browser
# falls back to the local stub patient (canned answers from case-content.js).
MODA_LLM_ENABLED=false

# HF Inference Providers — model selection.
# EN/FR traffic — Mistral-7B is well-tuned and cheap on the free tier.
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# JA traffic — Mistral-7B's Japanese is too weak for in-character roleplay;
# Qwen-2.5-7B is much stronger on CJK.
HF_MODEL_JA=Qwen/Qwen2.5-7B-Instruct

# Optional: override the endpoint URL (e.g. to a self-hosted HF Space).
# The function expects an OpenAI-compatible /v1/chat/completions surface.
# HF_URL=https://router.huggingface.co/v1/chat/completions
