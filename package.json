{
  "name": "canamed",
  "version": "0.0.0",
  "private": true,
  "description": "CaNaMED Franco-Japanese medical-education platform — research analysis + the live web app.",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:coverage": "c8 --reporter=text --reporter=lcov --reporter=html --include='docs/Third_session/PBL_platform/lib.js' --include='docs/Third_session/PBL_platform/i18n.js' --include='docs/Third_session/PBL_platform/localdb.js' --include='docs/Third_session/PBL_platform/telemetry.js' node --test tests/*.test.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "serve:platform": "node scripts/serve-platform.js",
    "i18n:coverage": "node scripts/i18n-coverage-report.js"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.49.0",
    "c8": "^10.1.3"
  }
}
