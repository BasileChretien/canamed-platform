# Claude Code worktree-local config — not part of the project
.claude/
.agents/

# Firebase CLI local state
.firebase/
firebase-debug.log
*.log

# Node / Playwright build artefacts (E2E suite)
node_modules/
playwright-report/
test-results/
playwright/.cache/

# scripts/sim/simulate-session.js produces these — the harness itself is
# tracked; each run's screenshots + report are local artefacts.
sim-output/screens-*/
sim-output/feedback-*.md
sim-output/theme-audit/

# scripts/sim/sim-with-emulator.js generates these on every run as the
# emulator-compatible rule copy + companion firebase.json. They're
# deleted on clean exit but linger after a kill — keep them out of git.
docs/Third_session/PBL_platform/database.rules.emulator.json
docs/Third_session/PBL_platform/firebase.emulator.json

# Credentials — local-only reference copies of API keys, service-account
# JSONs, and similar. NEVER commit. The git-tracked counterparts hold only
# the public values (e.g., Firebase web apiKey + reCAPTCHA site key in
# firebase-config.js — both designed to be public per Firebase docs); the
# real secrets live ONLY in:
#   - GitHub repo secrets (FIREBASE_SERVICE_ACCOUNT_CANAMED_69785)
#   - Firebase Console (App Check → reCAPTCHA secret key)
.secrets/
*.sa.json
service-account*.json
recaptcha-*.txt

# OS junk
.DS_Store
Thumbs.db
