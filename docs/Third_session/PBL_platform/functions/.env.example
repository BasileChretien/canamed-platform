# Firebase Cloud Functions — params API config
# ─────────────────────────────────────────────────────────────────────
# Copy this file to `.env` (or `.env.<projectId>` for per-project overrides)
# and edit the values. The real file is .gitignored — never commit it.
#
# Secrets like HF_TOKEN do NOT belong here. Set them via:
#   firebase functions:secrets:set HF_TOKEN
# which stores them in Google Secret Manager (encrypted at rest, mounted
# only when the function runs).
# ─────────────────────────────────────────────────────────────────────

# Module A LLM-patient pilot. DORMANT until set to true.
# When false, hfPatient returns { state: "disabled" } and the browser
# falls back to the local stub patient (canned answers from case-content.js).
MODA_LLM_ENABLED=false

# HF Inference Providers — model selection.
# EN/FR traffic — Llama-3.1-8B-Instruct is universally available on the
# free tier as a chat model. Mistral-7B-Instruct-v0.3 was our original
# pick but HF reclassified it as text-completion-only (returns 400 "is
# not a chat model" on /v1/chat/completions).
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct

# JA traffic — Mistral-7B's Japanese is too weak for in-character roleplay;
# Qwen-2.5-7B is much stronger on CJK.
HF_MODEL_JA=Qwen/Qwen2.5-7B-Instruct

# Optional: override the endpoint URL (e.g. to a self-hosted HF Space).
# The function expects an OpenAI-compatible /v1/chat/completions surface.
# HF_URL=https://router.huggingface.co/v1/chat/completions

# App Check enforcement on the hfPatient callable. Defaults to false in
# the pilot because CANAMED_RECAPTCHA_SITE_KEY isn't set in firebase-
# config.js — turning this on right now would 401 every call. To enable:
#   1. Get a reCAPTCHA v3 site key + register with Firebase App Check
#   2. Set window.CANAMED_RECAPTCHA_SITE_KEY in firebase-config.js
#   3. Flip the line below to APP_CHECK_ENFORCE=true
#   4. firebase deploy --only functions,hosting
# See CLAUDE.md "Operational reminders" §4 for the full procedure.
APP_CHECK_ENFORCE=false

# ---------------------------------------------------------------------------
# Global daily cap on hfPatient turns across ALL users (Phase 4b cost controls,
# PR #224). index.js declares it as defineInt("HF_GLOBAL_DAILY_CAP",
# {default:4000}) — but a NON-INTERACTIVE `firebase deploy` refuses to assume a
# param default and aborts with "no value for ... HF_GLOBAL_DAILY_CAP". So it
# must be present here even when you want the default. (Discovered 2026-07-23
# deploying #224: the deploy failed until this was added.)
HF_GLOBAL_DAILY_CAP=4000

# ---------------------------------------------------------------------------
# ⚠️ THIS IS NOT THE ONLY ENV FILE. Firebase also loads a per-project override,
# functions/.env.<projectId> — for this project functions/.env.canamed-69785 —
# which carries HF_URL, EMAIL_ENABLED and the SMTP_* settings used by
# sendQueuedMail. Both files are gitignored, so a fresh clone (or a git
# WORKTREE, which does not copy gitignored files) has NEITHER, and
# `firebase deploy --only functions` will abort listing every missing param.
# When deploying from a new checkout/worktree, copy BOTH from a checkout that
# has them:
#   functions/.env                    (this file's real counterpart)
#   functions/.env.<projectId>        (HF_URL, EMAIL_ENABLED, SMTP_*)
# HF_TOKEN is NOT in either file — it lives in Secret Manager.
